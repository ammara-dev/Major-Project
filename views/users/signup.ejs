<% layout('/layouts/boilerplate') -%>

<h1 class="col-6 offset-4">SignUp on Wanderlust</h1>

<div class="row mb-3">
    <div class="col-6 offset-3">
<form action="/signup" method="POST" class="needs-validation" novalidate>

    <div class="mb-3">
        <label for="username" class="form-label">Username</label>
        <input 
        name="username" 
        type="text" 
        class="form-control"  
        id="username" 
        required>
        <div class="valid-feedback">
            Looks good!
          </div>
</div>
          
          <div class="mb-3">
            <label for="email" class="form-label">Email</label>
          <input 
          name="email" 
          type="email" 
          class="form-control" 
          id="email" 
          required>
          </div>

          <div class="mb-3">
            <label for="password" class="form-label">Password</label>
        <input 
        name="password" 
        type="password" 
        class="form-control" 
        id="password" 
        required>
          </div>
          <button class="btn btn-success">Sign Up</button>
</form>
    </div>
</div>